{
  "name": "sniffer-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"web,api\" --prefix-colors \"blue,green\" \"pnpm --filter @sniffer/web dev\" \"pnpm --filter @sniffer/analysis dev\"",
    "dev:web": "pnpm --filter @sniffer/web dev",
    "dev:api": "pnpm --filter @sniffer/analysis dev",
    "build": "pnpm --filter @sniffer/web build",
    "start": "concurrently --names \"web,api\" --prefix-colors \"blue,green\" \"pnpm --filter @sniffer/web start\" \"pnpm --filter @sniffer/analysis start\"",
    "lint": "pnpm --filter @sniffer/web lint",
    "install:py": "pnpm --filter @sniffer/analysis install:py"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
